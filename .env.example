# xAI Grok (OpenAI-compatible API at https://api.x.ai/v1)
# Get a key: https://console.x.ai — never commit real keys.
XAI_API_KEY=
# Default reasoning model (override per environment)
XAI_MODEL=grok-4.20-reasoning
# Set to true so /api/ai/summary returns 503 when XAI_API_KEY is missing (e.g. staging/CI).
# Omit or false for hackathon demos — mock JSON is returned instead.
# REQUIRE_XAI_API_KEY=true

# Supabase — optional for this prototype. When unset, the app uses mock auth (localStorage).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
